# Wenando SPA — Vite environment variables
# Copy to .env for local development (do not commit .env)

# API base URL (must include /api/v1)
VITE_API_URL=http://localhost:8000/api/v1

# Editorial CMS public API — set true when backend Sprint 1b routes are available
VITE_EDITORIAL_API=false

# Base URL for magazine article links (Laravel HTML pages)
# VITE_EDITORIAL_SITE_URL=https://wenando.com

# Production:
# VITE_API_URL=https://api.wenando.com/api/v1

# Optional: Laravel backend target for Vite dev proxy (see vite.config.js)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional captcha site keys (production)
# VITE_HCAPTCHA_SITE_KEY=
# VITE_RECAPTCHA_SITE_KEY=

# Dev: match backend WENANDO_WALLET_INSTANT_RECHARGE for immediate wallet credit in UI
# VITE_WALLET_INSTANT_RECHARGE=true

# Stripe (card recharge) — publishable key from Stripe Dashboard
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Error tracking (optional — inactive when unset)
# VITE_SENTRY_DSN=

# Map tiles for B2B coverage zone editor (OpenFreeMap default; MapTiler example below)
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
# VITE_MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_MAPTILER_KEY

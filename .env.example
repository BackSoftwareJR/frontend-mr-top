# Wenando SPA — Vite environment variables
# Copy to .env for local development (do not commit .env)

# API base URL (must include /api/v1)
VITE_API_URL=http://localhost:8000/api/v1

# Production:
# VITE_API_URL=https://api.wenando.com/api/v1

# Optional: Laravel backend target for Vite dev proxy (see vite.config.js)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional captcha site keys (production)
# VITE_HCAPTCHA_SITE_KEY=
# VITE_RECAPTCHA_SITE_KEY=

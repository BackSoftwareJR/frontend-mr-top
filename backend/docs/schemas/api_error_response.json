{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.wenando.com/schemas/api_error_response.json",
  "title": "Wenando API Error Envelope",
  "description": "Standard error response for all API v1 endpoints",
  "type": "object",
  "required": ["success", "error"],
  "additionalProperties": false,
  "properties": {
    "success": {
      "type": "boolean",
      "const": false
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]{2,63}$",
          "description": "Stable machine-readable error code",
          "examples": ["VALIDATION_FAILED", "OTP_EXPIRED", "INSUFFICIENT_CREDITS"]
        },
        "message": {
          "type": "string",
          "maxLength": 500,
          "description": "User-safe Italian message"
        },
        "details": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ],
          "description": "Field-level validation errors or structured context"
        }
      }
    },
    "trace_id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID for log correlation (production)"
    },
    "meta": {
      "type": "object",
      "properties": {
        "request_id": { "type": "string" },
        "retry_after_seconds": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
